# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Supabase (required) ---
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- GitHub App (required for GitHub integration + webhooks) ---
# Numeric App ID from GitHub → Settings → Developer settings → GitHub Apps → Your app
GITHUB_APP_ID=

# Private key from the same app page ("Generate a private key"). Either:
# - paste the full multi-line PEM as a single line with literal \n where line breaks were, or
# - use a .env line continuation / quoted block if your tooling supports it
GITHUB_APP_PRIVATE_KEY=

# Must exactly match the "Webhook secret" configured on your GitHub App
GITHUB_WEBHOOK_SECRET=

# --- GitHub App (optional today) ---
# Used if you later add OAuth or other flows that need the app's OAuth client
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
